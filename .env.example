SKILLHUB_ENV=development
SKILLHUB_DATABASE_URL=postgresql+psycopg://skillhub:change-me@postgres:5432/skillhub
SKILLHUB_ADMIN_TOKEN=replace-with-at-least-32-random-characters
SKILLHUB_ADMIN_SUBJECT=tark5139
SKILLHUB_PUBLIC_BASE_URL=http://localhost:8080

# local | s3
SKILLHUB_STORAGE_BACKEND=local
SKILLHUB_LOCAL_STORAGE_PATH=./var/storage
SKILLHUB_S3_ENDPOINT_URL=
SKILLHUB_S3_REGION=ap-shanghai
SKILLHUB_S3_QUARANTINE_BUCKET=skill-hub-quarantine
SKILLHUB_S3_RELEASE_BUCKET=skill-hub-release
SKILLHUB_S3_ACCESS_KEY_ID=
SKILLHUB_S3_SECRET_ACCESS_KEY=

SKILLHUB_MAX_ARCHIVE_BYTES=52428800
SKILLHUB_MAX_UNCOMPRESSED_BYTES=209715200
SKILLHUB_MAX_FILES=2000
SKILLHUB_MAX_COMPRESSION_RATIO=100
SKILLHUB_REQUIRE_SIGNATURE=false
SKILLHUB_TRUSTED_PUBLIC_KEYS_JSON={}

# GitHub is opt-in per Skill version. Prefer a GitHub App installation token in production.
SKILLHUB_GITHUB_OWNER=tark5139
SKILLHUB_GITHUB_REPOSITORY=skill-hub-public
SKILLHUB_GITHUB_TOKEN=
SKILLHUB_GITHUB_APPROVER=tark5139
