# Install as root-owned /etc/skill-hub/backup.env with mode 0640 and deployment-group read access.
# This is shell syntax sourced by backup.sh; keep it separate from the application .env.
BACKUP_COS_URI=s3://REPLACE_BACKUP_BUCKET_WITH_APPID/postgres
BACKUP_COS_ACCESS_KEY_ID=REPLACE_WITH_BACKUP_CAM_SECRET_ID
BACKUP_COS_SECRET_ACCESS_KEY=REPLACE_WITH_BACKUP_CAM_SECRET_KEY
SKILLHUB_S3_ENDPOINT_URL=https://cos.ap-shanghai.myqcloud.com
AWS_DEFAULT_REGION=ap-shanghai
RETENTION_DAYS=14
